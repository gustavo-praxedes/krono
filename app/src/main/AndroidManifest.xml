<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.krono.app">

    <!-- ========================================================
         PERMISSÕES
         ======================================================== -->

    <!-- Permite desenhar sobre outros apps (widget flutuante).
         NÃO é concedida automaticamente — o usuário precisa
         habilitá-la em Configurações > Apps > Acesso especial.
         Verificar Settings.canDrawOverlays(context) antes de usar. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Permite iniciar um Foreground Service. Concedida
         automaticamente — não requer aprovação do usuário. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- Android 14+: tipo obrigatório para foreground services
         que não se enquadram nos tipos padrão do sistema. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Permite receber o broadcast de boot completo para
         relançar o serviço após reinicialização do dispositivo. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Permite manter o processador ativo e a tela ligada
         enquanto o cronômetro estiver rodando. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Android 13+: obrigatória para exibir notificações.
         Deve ser solicitada em runtime pela MainActivity. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />


    <!-- Permição de vibração -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- ========================================================
         APLICAÇÃO
         ======================================================== -->
    <application
        android:name="com.krono.app.KronoApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Krono">

        <!-- ====================================================
             ACTIVITY PRINCIPAL — Tela de configurações
             ==================================================== -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:windowSoftInputMode="adjustResize">

            <!-- Ponto de entrada do app -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!-- ====================================================
             FOREGROUND SERVICE — Cronômetro + Overlay
             foregroundServiceType="specialUse" obrigatório no
             Android 14+ para serviços sem tipo padrão definido.
             stopWithTask="false" garante que o serviço continue
             rodando mesmo após o app ser removido dos recentes.
             ==================================================== -->
        <service
            android:name=".service.MainService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:stopWithTask="false" />

        <!-- ====================================================
             BOOT RECEIVER — Relança o serviço após reboot.
             exported="true" necessário pois o broadcast é
             enviado pelo sistema (processo externo ao app).
             ==================================================== -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="true"
            android:directBootAware="false">
            <intent-filter>
                <!-- Boot completo do Android -->
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <!-- Fast boot em dispositivos Xiaomi/HTC -->
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <!-- Relança após atualização do próprio app -->
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- ====================================================
             NOTIFICATION ACTION RECEIVER — Processa os botões
             da notificação persistente (Play/Pause/Reset/Fechar).
             exported="false": apenas o próprio app pode disparar
             essas ações via PendingIntent interno.
             ==================================================== -->
        <receiver
            android:name=".receiver.NotificationActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.krono.app.ACTION_PLAY" />
                <action android:name="com.krono.app.ACTION_PAUSE" />
                <action android:name="com.krono.app.ACTION_RESET" />
                <action android:name="com.krono.app.ACTION_STOP_SERVICE" />
                <action android:name="com.krono.app.ACTION_HIDE_OVERLAY" />
            </intent-filter>
        </receiver>

    </application>

</manifest>